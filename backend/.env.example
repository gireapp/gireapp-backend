# ─── GIREAPP Environment Variables ───
# Copy this file to .env and fill in the values.
# (The server also reads .env.local, but Prisma CLI commands like
#  `prisma migrate dev` / `prisma db push` only read .env — so prefer .env.)

# ── Database (Neon PostgreSQL) ──
DATABASE_URL="postgresql://user:password@host:5432/gireapp?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/gireapp?sslmode=require"

# ── Auth.js / NextAuth ──
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
# AUTH_TRUST_HOST=true  # Enable in production behind a proxy

# ── Email (Resend) ──
RESEND_API_KEY="re_xxxxxxxxxx"
EMAIL_FROM="GIREAPP <noreply@gireapp.com>"

# ── AWS S3 (Media Uploads) ──
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="af-south-1"
AWS_S3_BUCKET="gireapp-media"

# ── Rate Limiting (Upstash Redis) ──
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Error Monitoring (Sentry) ──
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ── Application ──
# CORS origin + base URL for links in emails (verification, password reset)
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GIREAPP"
NODE_ENV="development"

# Dev/testing only: auto-verifies new accounts and auto-logs-in on register.
# NEVER set this in production.
# SKIP_EMAIL_VERIFICATION="true"
