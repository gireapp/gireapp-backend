// ─────────────────────────────────────────────────
// GIREAPP — Prisma Schema
// All 10 core models with relations and indexes
// Aligned with PRD v1.0 and MVP Milestone Criteria
// ─────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum AcademicLevel {
  SECONDARY
  TERTIARY
  PROFESSIONAL
}

enum ContentType {
  TEXT
  PDF
  MARKDOWN
  VIDEO
}

enum BadgeType {
  BRONZE
  SILVER
  GOLD
  CURRENT_MASTER
}

// ── User ──

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  passwordHash  String
  role          Role          @default(STUDENT)
  academicLevel AcademicLevel?
  department    String?       // e.g., "Science", "Undergraduate", "Data Analytics"
  moodTheme     String?       @default("calm")
  points        Int           @default(0)
  emailVerified DateTime?
  image         String?
  deletedAt     DateTime?     // Soft delete (M5: BE-ADMIN-005)

  // Verification & reset tokens
  verificationToken String?   @unique
  verificationExpiry DateTime?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?

  // Brute-force protection (per-account lockout)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Relations
  enrolments    Enrolment[]
  quizAttempts  QuizAttempt[]
  badges        UserBadge[]
  lessonProgress LessonProgress[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([academicLevel, department])
  @@index([email])
  @@index([role])
  @@map("users")
}

// ── Course ──

model Course {
  id            String        @id @default(cuid())
  title         String
  description   String        @db.Text
  academicLevel AcademicLevel
  department    String        // Must match user's department for filtering
  thumbnailUrl  String?
  published     Boolean       @default(false)
  createdById   String?       // Tutor/Admin who created
  deletedAt     DateTime?     // Soft delete

  // Relations
  modules       Module[]
  enrolments    Enrolment[]
  quizzes       Quiz[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([academicLevel, department])
  @@index([published])
  @@map("courses")
}

// ── Module ──

model Module {
  id       String   @id @default(cuid())
  courseId  String
  title    String
  order    Int      @default(0)

  // Relations
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, order])
  @@map("modules")
}

// ── Lesson ──

model Lesson {
  id               String      @id @default(cuid())
  moduleId         String
  title            String
  contentType      ContentType @default(TEXT)
  content          String?     @db.Text  // For TEXT/MARKDOWN
  mediaUrl         String?               // For PDF/VIDEO (S3 URL)
  order            Int         @default(0)
  estimatedMinutes Int         @default(10)

  // Relations
  module           Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress         LessonProgress[]

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([moduleId, order])
  @@map("lessons")
}

// ── Enrolment ──

model Enrolment {
  id        String   @id @default(cuid())
  userId    String
  courseId   String
  progress  Float    @default(0) // 0.0 to 1.0

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@map("enrolments")
}

// ── Lesson Progress ──

model LessonProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(true)

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("lesson_progress")
}

// ── Quiz ──

model Quiz {
  id           String   @id @default(cuid())
  courseId      String
  title        String
  description  String?
  timeLimitMin Int      @default(30) // Timer enforcement (M4)
  passingScore Int      @default(70) // Percentage to pass

  // Relations
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions    Question[]
  attempts     QuizAttempt[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([courseId])
  @@map("quizzes")
}

// ── Question ──

model Question {
  id           String         @id @default(cuid())
  quizId       String
  text         String         @db.Text
  explanation  String?        @db.Text // Shown after grading
  order        Int            @default(0)

  // Relations
  quiz         Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choices      AnswerChoice[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([quizId, order])
  @@map("questions")
}

// ── Answer Choice ──

model AnswerChoice {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)

  // Relations
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("answer_choices")
}

// ── Quiz Attempt ──

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int      // Percentage 0–100
  totalRight  Int
  totalWrong  Int
  answers     Json     // { questionId: choiceId } map
  startedAt   DateTime @default(now())
  submittedAt DateTime @default(now())
  timeTakenSec Int?    // Actual seconds spent

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId, quizId])
  @@index([quizId])
  @@map("quiz_attempts")
}

// ── User Badge ──

model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  badgeType BadgeType
  courseId   String?   // Which course the badge was earned for
  earnedAt  DateTime  @default(now())

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType, courseId])
  @@map("user_badges")
}
